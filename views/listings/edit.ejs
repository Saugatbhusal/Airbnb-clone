<% layout('/layouts/boilerplate') -%>

    <body>
        <div class="row">
            <div class="col col-8 offset-2">
                <h3>Edit new List</h3>
                <form method="post" action="/listings/<%=listing.id%>/?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label for="title">Enter title</label>
                        <input type="text" name="listing[title]" class="form-control" value="<%=listing.title%>" required>
                        <div class="invalid-feedback"> Enter a title</div>

                    </div>
                    <div class="mb-4">
                        <label for="description">Edit description</label>
                        <textarea name="listing[description]" type="text" class="form-control" required><%=listing.description%></textarea>
                        <div class="invalid-feedback"> Enter description</div>
                    </div>
                    <div class="mb-4">
                        <label for="location">Edit location</label>
                        <input type="text " class="form-control" name="listing[location]" value="<%=listing.location%>" required>
                        <div class="invalid-feedback"> Enter valid location</div>
                    </div>
                    <div class="mb-4">
                        <img src="<%=originalUrl%>" alt="Original image">

                    </div>
                    <div class="mb-4">
                        <label for="image">Upload new img</label>
                        <input type="file" class="form-control" name="listing[image]">

                    </div>
                    <div class=" row ">
                        <div class="col col-4 ">
                            <div class=" mb-4 ">
                                <label for="price ">Price</label>
                                <input name="listing[price]" value="<%=listing.price%>" required>
                                <div class="invalid-feedback">Enter valid price</div>
                            </div>
                        </div>
                        <div class="col col-8 ">
                            <div class="mb-4 ">

                                <label for="country ">country</label>
                                <input type="text " name="listing[country]" value="<%=listing.country%>" required>
                                <div class="invalid-feedback"> Enter valid country name.</div>
                            </div>
                        </div>
                    </div>




                    <button class="btn btn-dark edit-btn mb-4 ">edit</button>
                </form>
            </div>

        </div>

    </body>